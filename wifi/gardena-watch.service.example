[Unit]
Description=Gardena Sileno websocket live status watcher
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/gardena-sileno-toolkit/wifi
ExecStart=/home/YOUR_USER/gardena-sileno-toolkit/wifi/.venv/bin/python /home/YOUR_USER/gardena-sileno-toolkit/wifi/watch.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
